{
  "manifest_version": 3,
  "name": "Solscan Jito Bundle Detector",
  "version": "2.2",
  "description": "Detects if a transaction on Solscan is a Jito bundle",

  "permissions": [],

  "host_permissions": [
    "https://bundles.jito.wtf/*"
  ],

  "background": {
    "service_worker": "background.js"
  },

  "content_scripts": [
    {
      "matches": ["https://solscan.io/*", "https://photon-sol.tinyastro.io/*"],
      "js": ["content.js"],
      "run_at": "document_end"
    }
  ],

  "icons": {
    "16": "icons/16.png",
    "48": "icons/48.png",
    "128": "icons/128.png"
  }
}
